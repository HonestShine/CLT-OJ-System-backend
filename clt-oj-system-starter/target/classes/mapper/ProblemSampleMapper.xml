<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.clt.mapper.ProblemSampleMapper">

    <!--  添加题目样例  -->
    <insert id="insert">
        INSERT INTO problem_samples (problem_id, sample_order, input_content, output_content, is_example)
        VALUES (#{problemId}, #{sampleOrder}, #{inputContent}, #{outputContent}, #{isExample})
    </insert>

    <!--  通过题目ID删除题目样例  -->
    <delete id="deleteByProblemId">
        DELETE FROM problem_samples WHERE problem_id = #{id}
    </delete>

    <!--  通过题目ID获取例题列表  -->
    <select id="getProblemSampleListByProblemId" resultType="com.clt.entity.ProblemSample">
        SELECT * FROM problem_samples WHERE problem_id = #{id} AND is_example = 1
    </select>

    <!--  获取题目样例列表  -->
    <select id="getProblemSampleList" resultType="com.clt.entity.ProblemSample">
        SELECT * FROM problem_samples
    </select>

</mapper>